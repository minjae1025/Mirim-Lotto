	//자신이 입력한 번호 출력
	void numberPrint(int cnt) {
		System.out.print((cnt+1)+"번째 장 번호 : ");
		for (int j = 0; j<my_lotto[cnt].length; j++) {
			System.out.print(" |"+my_lotto[j]+"| ");
